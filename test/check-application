import testlib


@testlib.nondestructive
class TestApplication(testlib.MachineCase):
    def testBasic(self):
        b = self.browser

        self.login_and_go("/adsbcot")

        b.wait_visible("[data-testid=adsbcot-app]")
        b.wait_visible("[data-testid=adsbcot-service-card]")
        b.wait_visible("[data-testid=adsbcot-tls-card]")
        b.wait_visible("[data-testid=adsbcot-config-card]")


if __name__ == '__main__':
    testlib.test_main()
